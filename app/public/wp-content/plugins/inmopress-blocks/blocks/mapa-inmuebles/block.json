{
    "name": "inmopress/mapa-inmuebles",
    "title": "Mapa de Inmueble",
    "description": "Muestra la ubicación del inmueble en un mapa interactivo (Leaflet).",
    "category": "inmopress-blocks",
    "icon": "location-alt",
